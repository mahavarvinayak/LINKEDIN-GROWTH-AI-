# Next.js Application URL
NEXT_PUBLIC_APP_URL="http://localhost:3000"

# Supabase Configuration
NEXT_PUBLIC_SUPABASE_URL="your-supabase-project-url"
NEXT_PUBLIC_SUPABASE_ANON_KEY="your-supabase-anon-key"

# Secret service role key (Backend only)
SUPABASE_SERVICE_ROLE_KEY="your-supabase-service-role-key"

# AI Configuration (No OpenAI)
GEMINI_API_KEY="your-gemini-api-key"
GROQ_API_KEY="your-groq-api-key"

# NVIDIA NIM (Primary Provider)
# DeepSeek key (shared by Free + Starter, Free gets higher traffic share)
NVIDIA_API_KEY_DEEPSEEK="your-deepseek-nvidia-key"
NVIDIA_MODEL_DEEPSEEK="deepseek-ai/deepseek-v3.1-terminus"

# Moonshot key (shared by Starter + Pro, Starter gets higher traffic share)
NVIDIA_API_KEY_MOONSHOT="your-moonshot-nvidia-key"
NVIDIA_MODEL_MOONSHOT="moonshotai/kimi-k2-instruct"

# Common NVIDIA base URL
NVIDIA_BASE_URL="https://integrate.api.nvidia.com/v1"

# Backward-compatible legacy vars (optional)
# NVIDIA_PREMIUM_API_KEY, NVIDIA_SHARED_API_KEY
# NVIDIA_NIM_API_KEY_1, NVIDIA_NIM_API_KEY_2
