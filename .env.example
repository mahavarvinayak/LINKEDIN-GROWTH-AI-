# Next.js Application URL
NEXT_PUBLIC_APP_URL="http://localhost:3000"

# Supabase Configuration
NEXT_PUBLIC_SUPABASE_URL="your-supabase-project-url"
NEXT_PUBLIC_SUPABASE_ANON_KEY="your-supabase-anon-key"

# Secret service role key (Backend only)
SUPABASE_SERVICE_ROLE_KEY="your-supabase-service-role-key"

# AI Configuration (No OpenAI)
GEMINI_API_KEY="your-gemini-api-key"
GROQ_API_KEY="your-groq-api-key"

# NVIDIA NIM (Primary Provider)
# Use one or both keys for round-robin load balancing.
NVIDIA_NIM_API_KEY_1="your-nvidia-nim-api-key-1"
NVIDIA_NIM_API_KEY_2="your-nvidia-nim-api-key-2"

# If omitted, defaults to NVIDIA hosted endpoint.
NVIDIA_NIM_BASE_URL="https://integrate.api.nvidia.com/v1/chat/completions"

# Optional model override.
NVIDIA_NIM_MODEL="meta/llama-3.1-8b-instruct"
