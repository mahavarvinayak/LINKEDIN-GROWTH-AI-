# Next.js Application URL
NEXT_PUBLIC_APP_URL="http://localhost:3000"

# Supabase Configuration
NEXT_PUBLIC_SUPABASE_URL="your-supabase-project-url"
NEXT_PUBLIC_SUPABASE_ANON_KEY="your-supabase-anon-key"

# Secret service role key (Backend only)
SUPABASE_SERVICE_ROLE_KEY="your-supabase-service-role-key"

# AI Configuration (No OpenAI)
GEMINI_API_KEY="your-gemini-api-key"
GROQ_API_KEY="your-groq-api-key"

# NVIDIA NIM (Primary Provider)
# Premium users (starter/premium plan) -> Kimi model
NVIDIA_PREMIUM_API_KEY="your-premium-nvidia-key"
NVIDIA_PREMIUM_BASE_URL="https://integrate.api.nvidia.com/v1"
NVIDIA_PREMIUM_MODEL="moonshotai/kimi-k2-instruct"

# Free + Pro users -> DeepSeek model
NVIDIA_SHARED_API_KEY="your-shared-nvidia-key"
NVIDIA_SHARED_BASE_URL="https://integrate.api.nvidia.com/v1"
NVIDIA_SHARED_MODEL="deepseek-ai/deepseek-v3.1-terminus"

# Backward-compatible legacy vars (optional)
NVIDIA_NIM_API_KEY_1=""
NVIDIA_NIM_API_KEY_2=""
NVIDIA_NIM_BASE_URL="https://integrate.api.nvidia.com/v1"
NVIDIA_NIM_MODEL=""
